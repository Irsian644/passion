# Passion Dream — environment variables
#
# This file is a TEMPLATE and is committed to git.
# NEVER put real keys here. Copy it to .env.local and fill that in instead:
#   cp .env.example .env.local
#
# .env.local is gitignored. In production, set these in
# Vercel → Project → Settings → Environment Variables.
#
# Only NEXT_PUBLIC_* values reach the browser. Everything else is server-only.

# --- Supabase -------------------------------------------------------------
# Supabase → Project Settings → Data API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# "anon / public" key. Safe to expose: it is constrained by Row Level Security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" key. SECRET — bypasses Row Level Security entirely.
# Server-only. Never prefix with NEXT_PUBLIC_. Never import into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# --- Site -----------------------------------------------------------------
# Public origin, no trailing slash. Used for auth redirects (password reset).
NEXT_PUBLIC_SITE_URL=https://passion-sigma.vercel.app
